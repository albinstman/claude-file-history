{
  "name": "claude-file-history",
  "displayName": "Claude File History",
  "description": "See which Claude Code sessions touched any file — right-click or use the sidebar to view session history, resume conversations, and track tools used.",
  "version": "0.4.1",
  "publisher": "albinstman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/albinstman/claude-file-history"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeFileHistory.showSessions",
        "title": "Show Claude Sessions for This File"
      },
      {
        "command": "claudeFileHistory.runBackfill",
        "title": "Claude File History: Backfill from Historical Sessions"
      },
      {
        "command": "claudeFileHistory.refresh",
        "title": "Claude File History: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeFileHistory.installHooks",
        "title": "Claude File History: Reinstall Hooks"
      },
      {
        "command": "claudeFileHistory.resumeSession",
        "title": "Resume Session",
        "icon": "$(play)"
      },
      {
        "command": "claudeFileHistory.copySessionId",
        "title": "Copy Session ID",
        "icon": "$(clippy)"
      },
      {
        "command": "claudeFileHistory.copyResumeCommand",
        "title": "Copy Resume Command"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "claudeFileHistory.showSessions",
          "group": "navigation@100"
        }
      ],
      "editor/context": [
        {
          "command": "claudeFileHistory.showSessions",
          "group": "navigation@100"
        }
      ],
      "view/title": [
        {
          "command": "claudeFileHistory.refresh",
          "when": "view == claudeFileHistory.sessionTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeFileHistory.resumeSession",
          "when": "viewItem == session",
          "group": "inline@1"
        },
        {
          "command": "claudeFileHistory.copySessionId",
          "when": "viewItem == session",
          "group": "inline@2"
        },
        {
          "command": "claudeFileHistory.resumeSession",
          "when": "viewItem == session",
          "group": "session@1"
        },
        {
          "command": "claudeFileHistory.copySessionId",
          "when": "viewItem == session",
          "group": "session@2"
        },
        {
          "command": "claudeFileHistory.copyResumeCommand",
          "when": "viewItem == session",
          "group": "session@3"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeFileHistory",
          "title": "Claude File History",
          "icon": "$(history)"
        }
      ]
    },
    "views": {
      "claudeFileHistory": [
        {
          "id": "claudeFileHistory.sessionTree",
          "name": "Sessions"
        }
      ]
    }
  },
  "scripts": {
    "build": "node build.js",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "node build.js"
  },
  "dependencies": {
    "@claude-file-history/backfill": "*",
    "@claude-file-history/shared": "*",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.5.0"
  }
}
